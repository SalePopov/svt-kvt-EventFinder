### Backend - Spring Boot / Maven ###

# Generisani build folder
/backend/target/

# Log fajlovi
/backend/logs/
*.log

# Maven wrapper folder
/backend/.mvn/

# Fajlovi koje generiše Eclipse (za svaki slučaj)
.metadata
.classpath
.project
.settings

### Frontend - Angular / Node ###

# Ogromni folder sa zavisnostima - NAJVAŽNIJE PRAVILO!
/frontend/node_modules/

# Generisani build folder
/frontend/dist/

# Privremeni folderi
/frontend/tmp/

# Angular cache
/frontend/.angular/

# Log fajlovi generisani od strane npm-a
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor-specifični fajlovi
/frontend/.vscode/
